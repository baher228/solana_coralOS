[Unit]
Description=TxOdds Coral review panel agents
After=network.target txodds-api.service txodds-coral-bus.service

[Service]
Type=simple
WorkingDirectory=/opt/solana_coralOS/examples/txodds
Environment=KIT_ENV=/opt/solana_coralOS/.env.production
Environment=REVIEW_PANEL_ROLE=all
ExecStart=/usr/bin/env npm run agent:review-panel
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
