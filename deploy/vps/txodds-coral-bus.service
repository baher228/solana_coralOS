[Unit]
Description=TxOdds local Coral bus
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/solana_coralOS/examples/txodds
Environment=KIT_ENV=/opt/solana_coralOS/.env.production
ExecStart=/usr/bin/env npm run coral:bus
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
