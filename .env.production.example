# Copy to .env.production on the VPS and replace YOUR_VPS_IP.
# Keep this file public-safe; put real keys only in .env.production.

PUBLIC_BASE_URL=http://YOUR_VPS_IP
CORS_ALLOWED_ORIGINS=http://YOUR_VPS_IP
MCP_ALLOWED_ORIGINS=http://YOUR_VPS_IP

PORT=8801
CORAL_BUS_API=http://127.0.0.1:8001
CORAL_CONNECTION_URL=http://127.0.0.1:8001/mcp
PLATFORM_API_URL=http://127.0.0.1:8801
AUTO_RELEASE_MS=0

DEMO_PUBLIC_PREVIEW_BASE_URL=http://YOUR_VPS_IP/previews/
DEMO_DELIVERY_DIR=/var/lib/txodds/previews
DEMO_SESSION_TTL_MS=3600000
DEMO_MAX_WORKERS=2

BUYER_KEYPAIR_B58=
SELLER_KEYPAIR_B58=
WALLET=
SOLANA_RPC_URL=https://api.devnet.solana.com

AGENT_API_TOKEN=
AGENT_TRANSPORT=api
BID_WINDOW_MS=30000
ESCROW_DEADLINE_SECS=259200
DEMO_AGENT_POLL_MS=3000

CORAL_BUS_PORT=8001
MARKETPLACE_WORKER_AGENTS=demo-worker
MARKETPLACE_REVIEW_AGENTS=worker-advocate,employer-advocate,referee
REVIEW_PANEL_ROLE=all
REVIEW_PANEL_WAIT_MS=120000

AGENT_NAME=demo-worker
DEMO_WORKER_WALLET=
DEMO_BID_PRICE_SOL=
DEMO_DELIVERY_URL=
DEMO_DELIVERY_REPO=
DEMO_DELIVERY_NOTES=
DEMO_DELIVERY_PORT=4177
DEMO_DELIVERY_DELAY_MS=1500
DEMO_TARGET_JOB_ID=
DEMO_REVIEW_MODE=coral-panel

# Optional review brain. Without this, the demo uses deterministic local review.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=
LLM_MODEL=
