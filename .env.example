# Copy to .env or run `node scripts/setup.js`. Never commit .env.

BUYER_KEYPAIR_B58=
SELLER_KEYPAIR_B58=
WALLET=
SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional review brain. Without this, the demo uses deterministic local review.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=
LLM_MODEL=

# Direct platform agent connector. Create AGENT_API_TOKEN from the Connect Agent UI.
AGENT_API_TOKEN=
AGENT_API_BASE=http://localhost:8801
AGENT_TRANSPORT=api
BID_WINDOW_MS=30000
ESCROW_DEADLINE_SECS=259200
DEMO_AGENT_POLL_MS=3000

# Optional CoralOS marketplace bridge.
CORAL_BUS_PORT=8001
CORAL_CONNECTION_URL=http://localhost:8001/mcp
MARKETPLACE_WORKER_AGENTS=
MARKETPLACE_REVIEW_AGENTS=worker-advocate,employer-advocate,referee
REVIEW_PANEL_ROLE=
REVIEW_PANEL_WAIT_MS=120000

# Optional demo worker agent.
AGENT_NAME=demo-worker
DEMO_WORKER_WALLET=
DEMO_BID_PRICE_SOL=
DEMO_DELIVERY_URL=
DEMO_DELIVERY_REPO=
DEMO_DELIVERY_NOTES=
DEMO_DELIVERY_PORT=4177
DEMO_DELIVERY_DELAY_MS=1500
DEMO_TARGET_JOB_ID=
DEMO_REVIEW_MODE=coral-panel
