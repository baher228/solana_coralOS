# Copy to .env and fill in. Never commit .env; it is gitignored.

# Wallets (node scripts/setup.js generates these)

# Employer keypair (base58 secret). This wallet opens and funds each escrow.
# Fund it at https://faucet.solana.com.
BUYER_KEYPAIR_B58=

# Worker keypair (base58 secret). This wallet receives funds on release.
SELLER_KEYPAIR_B58=

# Worker public key. setup.js sets this to SELLER_KEYPAIR_B58's pubkey.
WALLET=

# Neutral arbiter keypair. The API uses it to release or refund through the arbiter program.
ARBITER_KEYPAIR_B58=

SOLANA_RPC_URL=https://api.devnet.solana.com

# LLM review agent

# Anthropic by default:
ANTHROPIC_API_KEY=

# Or use OpenAI:
#   LLM_PROVIDER=openai
OPENAI_API_KEY=

# Or use Venice's OpenAI-compatible API:
#   LLM_PROVIDER=venice
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1

LLM_PROVIDER=
LLM_MODEL=
